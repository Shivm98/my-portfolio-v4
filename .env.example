# SMTP (set these in Vercel → Project → Settings → Environment Variables)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
# Use true for port 465 (implicit TLS)
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_TO=

# Optional override if you omit emailSubject in src/content/portfolio.json
# MAIL_SUBJECT_PREFIX=Portfolio inquiry
